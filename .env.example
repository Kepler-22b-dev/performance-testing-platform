# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/perftest

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_SSL=false
REDIS_SSL_CERT_REQS=required
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5

# Agent reliability
AGENT_HEARTBEAT_INTERVAL=5
COMMAND_TTL_SECONDS=300
COMMAND_CLAIM_IDLE_MS=30000
COMMAND_DEDUP_TTL_SECONDS=604800

# Web security
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Artifact storage: filesystem (single-node/dev) or s3 (MinIO/AWS S3)
ARTIFACT_STORE_BACKEND=filesystem
ARTIFACT_LOCAL_DIR=./artifacts
# Keep true during rolling upgrades; set false after every Agent supports artifacts.
ARTIFACT_INLINE_FALLBACK=true
S3_ENDPOINT_URL=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=performance-testing-platform
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_SESSION_TOKEN=
S3_USE_SSL=false
CSV_MAX_UPLOAD_BYTES=104857600
