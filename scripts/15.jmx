        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor">
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="script">import javax.crypto.Cipher
import javax.crypto.spec.IvParameterSpec
import javax.crypto.spec.SecretKeySpec
import java.security.spec.AlgorithmParameterSpec
import org.apache.commons.codec.binary.Base64

// 胜聪的参数，不知道干啥用
def ak = &apos;aZ3uXd2hXupRxvHZ&apos;
def iv = &apos;1513D520B9C1459C&apos;

def activityId = vars.get(&quot;activityId&quot;) as Integer
def randomCode = vars.get(&quot;randomCode&quot;)
//口令
def watchword = vars.get(&quot;watchword&quot;)
def timestamp = System.currentTimeMillis()

// 构建参数对象
def params = [
    activityId: activityId,
    randomCode: randomCode,
    watchword: watchword,
    timestamp: timestamp
]

// 转换为JSON字符串
def content = new groovy.json.JsonBuilder(params).toString()

// 执行AES加密
def sign = cbcEncrypt(ak, iv, content)

// 设置JMeter变量
vars.put(&quot;timestamp&quot;, timestamp.toString())
vars.put(&quot;sign&quot;, sign)

// AES CBC加密方法
String cbcEncrypt(String aesKey, String ivSeed, String content) {
    try {
        // 参数校验
        if (!aesKey || !ivSeed || !content) {
            throw new Exception(&quot;参数不完整&quot;)
        }
        
        // 将密钥和IV转换为字节数组
        byte[] keyBytes = aesKey.getBytes(&quot;UTF-8&quot;)
        byte[] ivBytes = ivSeed.getBytes(&quot;UTF-8&quot;)
        
        // 创建密钥和IV规范
        SecretKeySpec keySpec = new SecretKeySpec(keyBytes, &quot;AES&quot;)
        AlgorithmParameterSpec ivSpec = new IvParameterSpec(ivBytes)
        
        // 初始化加密器
        Cipher cipher = Cipher.getInstance(&quot;AES/CBC/PKCS5Padding&quot;)
        cipher.init(Cipher.ENCRYPT_MODE, keySpec, ivSpec)
        
        // 执行加密
        byte[] encrypted = cipher.doFinal(content.getBytes(&quot;UTF-8&quot;))
        
        // Base64编码并替换特殊字符
        String encryptContent = Base64.encodeBase64String(encrypted)
        return encryptContent.replace(&quot;+&quot;, &quot;%2B&quot;).replace(&quot;/&quot;, &quot;%2F&quot;)
        
    } catch (Exception e) {
        log.error(&quot;AES CbcEncrypt 加密错误!&quot;, e)
        return &quot;&quot;
    }
}</stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
        </JSR223PreProcessor>
